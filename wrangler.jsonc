{
  "name": "morform",
  "main": "worker.js",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "404-page",
    "run_worker_first": true
  },
  "routes": [
    { "pattern": "morform.app", "custom_domain": true },
    { "pattern": "www.morform.app", "custom_domain": true }
  ]
}
